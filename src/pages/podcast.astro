---
import Layout from '../layouts/Layout.astro';

const episodes = [
  // Add episodes here as you publish them
  // {
  //   title: "Episode Title",
  //   date: "March 19, 2026",
  //   description: "Episode description...",
  //   spotifyUrl: "https://open.spotify.com/episode/..."
  // }
];
---

<Layout title="Podcast | Charles Christopher Rodriguez">
  <h1 class="text-4xl font-bold mb-4">Podcast</h1>
  
  <p class="text-gray-600 mb-8">
    Short-form conversations and thoughts on work, life, and everything in between. 
    Coming soon to Spotify.
  </p>
  
  <div class="bg-gray-50 rounded-lg p-8 text-center">
    <svg class="w-12 h-12 mx-auto mb-4 text-green-500" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.56.3z"/>
    </svg>
    
    <h2 class="text-xl font-semibold mb-2">Coming Soon</h2>
    <p class="text-gray-600">
      Episodes will be available on Spotify. Check back for updates!
    </p>
  </div>
  
  {episodes.length > 0 && (
    <div class="mt-12">
      <h2 class="text-2xl font-semibold mb-6">Episodes</h2>
      <div class="space-y-6">
        {episodes.map(episode => (
          <article class="border border-gray-200 rounded-lg p-6">
            <h3 class="text-lg font-semibold mb-1">{episode.title}</h3>
            <time class="text-sm text-gray-500">{episode.date}</time>
            <p class="text-gray-600 mt-2">{episode.description}</p>
            <a 
              href={episode.spotifyUrl} 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 mt-4 text-green-600 hover:text-green-700 font-medium"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.56.3z"/>
              </svg>
              Listen on Spotify
            </a>
          </article>
        ))}
      </div>
    </div>
  )}
</Layout>
