---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | Charles Christopher Rodriguez">
  <h1 class="text-4xl font-bold mb-8">About</h1>
  
  <div class="prose prose-lg max-w-none">
    <p class="text-xl text-gray-600 leading-relaxed mb-8">
      Hi, I'm Charles Christopher Rodriguez. I'm based in Wilmington, North Carolina, 
      and I'm passionate about [your profession/interests].
    </p>
    
    <h2 class="text-2xl font-semibold mt-12 mb-4">Career</h2>
    <p class="text-gray-600 mb-4">
      [Your career summary goes here. What do you do? What have you accomplished? 
      What are you known for?]
    </p>
    
    <h2 class="text-2xl font-semibold mt-12 mb-4">Milestones</h2>
    <ul class="space-y-4 text-gray-600">
      <li>
        <strong>2026</strong> — Launched personal website and began publishing articles
      </li>
      <li>
        <strong>[Year]</strong> — [Major milestone]
      </li>
      <li>
        <strong>[Year]</strong> — [Another milestone]
      </li>
    </ul>
    
    <h2 class="text-2xl font-semibold mt-12 mb-4">Connect</h2>
    <p class="text-gray-600">
      You can find me on:
    </p>
    
    <ul class="space-y-2 text-gray-600 mt-4">
      <li><a href="#" class="text-blue-600 hover:underline">LinkedIn</a></li>
      <li><a href="#" class="text-blue-600 hover:underline">Twitter/X</a></li>
      <li><a href="#" class="text-blue-600 hover:underline">GitHub</a></li>
    </ul>
  </div>
</Layout>
