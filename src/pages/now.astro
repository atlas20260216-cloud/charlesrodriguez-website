---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Now | Charles Christopher Rodriguez">
  <h1 class="text-4xl font-bold mb-4">What I'm up to now</h1>
  
  <p class="text-gray-500 text-sm mb-12">
    Last updated: March 19, 2026
  </p>
  
  <div class="space-y-12">
    <section>
      <h2 class="text-xl font-semibold mb-4">Work</h2>
      <p class="text-gray-600">
        [What are you working on professionally? Current projects, goals, etc.]
      </p>
    </section>
    
    <section>
      <h2 class="text-xl font-semibold mb-4">Learning</h2>
      <ul class="space-y-2 text-gray-600">
        <li>Reading: <em>12 Rules for Life</em> by Jordan Peterson</li>
        <li>Exploring AI tools and their practical applications</li>
        <li>Building this website with Astro</li>
      </ul>
    </section>
    
    <section>
      <h2 class="text-xl font-semibold mb-4">Playing</h2>
      <ul class="space-y-2 text-gray-600">
        <li>Competitive cornhole — working on my mental game and trying L-Theanine for focus</li>
        <li>Exploring new restaurants in Wilmington</li>
      </ul>
    </section>
    
    <section>
      <h2 class="text-xl font-semibold mb-4">Location</h2>
      <p class="text-gray-600">
        Wilmington, North Carolina
      </p>
    </section>
  </div>
  
  <hr class="my-12 border-gray-100" />
  
  <p class="text-sm text-gray-500">
    This is a <a href="https://nownownow.com/about" class="text-blue-600 hover:underline">now page</a>. 
    If you have your own site, you should make one too.
  </p>
</Layout>
