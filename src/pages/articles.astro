---
import Layout from '../layouts/Layout.astro';

const articles = [
  {
    title: "Welcome to my site",
    date: "March 19, 2026",
    excerpt: "This is the beginning of something new. I'm excited to share my thoughts, experiences, and what I'm learning along the way.",
    slug: "welcome"
  }
];
---

<Layout title="Articles | Charles Christopher Rodriguez">
  <h1 class="text-4xl font-bold mb-8">Articles</h1>
  
  <p class="text-gray-600 mb-12">
    Thoughts on work, life, and everything in between.
  </p>
  
  <div class="space-y-8">
    {articles.map(article => (
      <article class="border-b border-gray-100 pb-8">
        <a href={`/articles/${article.slug}`} class="group block">
          <h2 class="text-2xl font-semibold group-hover:text-gray-600 transition mb-2">
            {article.title}
          </h2>
          <time class="text-sm text-gray-500">{article.date}</time>
          <p class="text-gray-600 mt-3">{article.excerpt}</p>
          <span class="inline-block mt-4 text-sm text-gray-900 font-medium">
            Read more →
          </span>
        </a>
      </article>
    ))}
  </div>
</Layout>
